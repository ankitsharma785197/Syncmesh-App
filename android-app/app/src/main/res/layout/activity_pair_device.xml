<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app_background"
    android:orientation="vertical">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:backgroundTint="@color/syncmesh_surface"
        android:elevation="0dp"
        android:navigationIcon="@android:drawable/ic_menu_close_clear_cancel"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        app:title="@string/pair_activity_title"
        app:titleTextColor="@color/syncmesh_text" />

    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/pair_fragment_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />
</LinearLayout>
